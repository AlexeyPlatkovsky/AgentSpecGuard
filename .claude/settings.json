{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(bd:*)",
      "Bash(bd list:*)",
      "Bash(git add:*)"
    ],
    "ask": [
      "Bash(git checkout:*)",
      "Bash(git commit -m ':*)",
      "Bash(cat .benchmark/**)",
      "Read(.benchmark/**)",
      "Write(.benchmark/**)"
    ],
    "deny": []
  }
}